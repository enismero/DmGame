  m_Script: {fileID: 11500000, guid: e75f633176318c3419d1193e4d7c4500, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueManager
  taskManager: {fileID: 657706161}
  SpawnQuestAmount: 8
  gameManager: {fileID: 657706157}
  dialogueText: {fileID: 1494279833}
  typingSpeed: 0.05
  maxCharacters: 20
  messages:
  - Hello, I'm Postman Robbert. I bought new Quest papers and left them on your desk.
  - You can click and drag the papers.
  - You can double click any paper to see the  quest details. Choosing the right
    hero for the right job is key to succest.
  - Every piece of paper here is waiting to adventurer.
  - If you don't like a quest or think you can't complete it. just drag it and drop
    it back to me.
  - 'Rain or shine, I will be here each morning with the new quests from the Guild. '
  - Well, tha's all from me for now.
  openHeroPaper: {fileID: 1662613159}
  walkTo: {fileID: 1662613158}
